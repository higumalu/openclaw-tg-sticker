{
  "id": "tg-sticker-reply",
  "name": "Telegram sticker reply",
  "description": "Global sticker library (JSON), CRUD tools, and Telegram prompt policy for optional sticker channel actions.",
  "contracts": {
    "tools": [
      "tg_sticker_add",
      "tg_sticker_update",
      "tg_sticker_remove",
      "tg_sticker_list",
      "tg_sticker_get"
    ]
  },
  "toolMetadata": {
    "tg_sticker_add": { "optional": true },
    "tg_sticker_update": { "optional": true },
    "tg_sticker_remove": { "optional": true },
    "tg_sticker_list": { "optional": true },
    "tg_sticker_get": { "optional": true }
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "maxCatalogLines": {
        "type": "number",
        "description": "Max sticker lines in injected Telegram prompt (1–500, default 40)",
        "minimum": 1,
        "maximum": 500
      },
      "enableStickerSearchHint": {
        "type": "boolean",
        "description": "Include sticker-search fallback guidance (default true)"
      },
      "migrateLegacyStickerMap": {
        "type": "boolean",
        "description": "Merge legacy stickerMap from config into data/sticker-library.json"
      },
      "stickerMap": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Legacy alias → file_id (used when migrateLegacyStickerMap is true)"
      }
    }
  }
}
